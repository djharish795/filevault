generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String
  name          String
  isMasterAdmin Boolean         @default(false)
  createdAt     DateTime        @default(now())
  auditLogs     AuditLog[]
  fileAccess    FileAccess[]
  ownedFiles    File[]
  projects      ProjectMember[]
}

model Project {
  id         String          @id @default(uuid())
  name       String
  caseNumber String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  auditLogs  AuditLog[]
  files      File[]
  folders    Folder[]
  members    ProjectMember[]
}

// Virtual subfolder inside a project — supports infinite nesting via parentId
model Folder {
  id        String   @id @default(uuid())
  name      String
  projectId String
  parentId  String?
  createdAt DateTime @default(now())
  children  Folder[] @relation("FolderTree")
  files     File[]
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model File {
  id          String       @id @default(uuid())
  projectId   String
  folderId    String?      // null = root of project, set = inside a subfolder
  ownerId     String
  name        String
  mimeType    String
  size        Int
  storageKey  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  auditLogs   AuditLog[]
  sharedWith  FileAccess[]
  folder      Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Tracks which users have been explicitly granted access to a specific file
model FileAccess {
  id        String   @id @default(uuid())
  fileId    String
  userId    String
  grantedAt DateTime @default(now())
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fileId, userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  projectId String?
  fileId    String?
  metadata  Json?
  createdAt DateTime @default(now())
  file      File?    @relation(fields: [fileId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([fileId])
  @@index([createdAt])
}
